{
  "expo": {
    "name": "vl-helper",
    "slug": "vl-helper",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "nyc.qiao.vlhelper"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "nyc.qiao.vlhelper",
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow vl-helper to access your photos for blog posts."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow vl-helper to access your photos.",
          "savePhotosPermission": "Allow vl-helper to save photos."
        }
      ]
    ],
    "scheme": "vlhelper"
  }
}
